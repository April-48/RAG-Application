# ----------------------------------------------------------------------------
# RAG Application - backend / middleware environment template
# Copy to `.env` in the repository root. Never commit `.env`.
#
# Frontend variables (VITE_*) live in `frontend/.env` — see frontend/.env.example.
# ----------------------------------------------------------------------------

# --- Postgres / pgvector ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=rag_app
POSTGRES_PORT=5432

# Connection string used by the middleware + backend (SQLAlchemy / Alembic).
#
# WHERE IS THE APP RUNNING?
#   Host machine (recommended MVP): middleware on localhost:8000, DB/Redis via
#     published compose ports → use localhost below.
#   Inside Docker Compose (future): middleware container must use service names,
#     NOT localhost (localhost = the middleware container itself):
#       DATABASE_URL=postgresql+psycopg://postgres:password@db:5432/rag_app
#       REDIS_URL=redis://redis:6379/0
#
POSTGRES_HOST=localhost
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/rag_app

# --- JWT auth ---
# Use a long random secret in any shared/demo environment. Do not commit real .env.
JWT_SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Embeddings (swappable provider) ---
# EMBEDDING_PROVIDER: local | openai
# Keep EMBEDDING_MODEL and EMBEDDING_DIM consistent with the pgvector column:
#   local   all-MiniLM-L6-v2       -> 384   (default; free / offline)
#   openai  text-embedding-3-small -> 1536
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- LLM (chat stage) ---
OPENAI_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
# Optional OpenAI-compatible endpoint (OpenRouter, Ollama, vLLM). Leave blank for OpenAI.
LLM_BASE_URL=

# --- Redis cache (optional answer cache) ---
# Caches repeated RAG answers for the same (user, document, question). The app
# degrades gracefully if Redis is down — chat still works without the cache.
#
# Demo / interview: keep ENABLE_REDIS_CACHE=true and run `docker compose up -d redis`,
# then ask the same question twice and mention the cache hit in backend logs.
# Minimal local dev without Redis: set ENABLE_REDIS_CACHE=false.
#
# Host machine:  REDIS_URL=redis://localhost:6379/0
# In compose:     REDIS_URL=redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
ENABLE_REDIS_CACHE=true
CACHE_TTL_SECONDS=3600

# --- Storage ---
UPLOAD_DIR=backend/storage/uploads

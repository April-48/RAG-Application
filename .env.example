# ----------------------------------------------------------------------------
# RAG Application — environment template
# Copy to `.env` in the repository root. Never commit `.env`.
#
# Frontend Vite vars: also set VITE_API_BASE_URL in docker-compose for the
# frontend service, or copy frontend/.env.example → frontend/.env for host dev.
# ----------------------------------------------------------------------------

# --- Postgres / pgvector ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=rag_app
POSTGRES_PORT=5432

# --- Database & Redis connection strings ---
#
# Docker Compose (middleware container — use service names db / redis):
DATABASE_URL=postgresql+psycopg://postgres:password@db:5432/rag_app
REDIS_URL=redis://redis:6379/0
#
# Local host (API + Alembic on your laptop, DB/Redis via published compose ports):
# DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/rag_app
# REDIS_URL=redis://localhost:6379/0

POSTGRES_HOST=localhost

# --- JWT auth ---
JWT_SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Embeddings (swappable provider) ---
# EMBEDDING_PROVIDER: local | openai
# Keep EMBEDDING_MODEL and EMBEDDING_DIM consistent with the pgvector column:
#   local   all-MiniLM-L6-v2       -> 384   (default; free / offline)
#   openai  text-embedding-3-small -> 1536
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- LLM (chat stage) ---
OPENAI_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
# Optional OpenAI-compatible endpoint (OpenRouter, Ollama, vLLM). Leave blank for OpenAI.
LLM_BASE_URL=

# --- Redis answer cache (optional, fail-open) ---
ENABLE_REDIS_CACHE=true
CACHE_TTL_SECONDS=3600

# --- Redis chat rate limit (optional, fail-open) — POST /chat/.../ask only ---
ENABLE_RATE_LIMIT=true
CHAT_RATE_LIMIT_PER_MINUTE=10

# --- Retrieval tuning (semantic mode) ---
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SIMILARITY=0.32

# --- Storage (relative to repo / container WORKDIR /app) ---
UPLOAD_DIR=backend/storage/uploads

# --- Frontend (host dev only; Docker Compose sets this on the frontend service) ---
# VITE_API_BASE_URL=http://localhost:8000
